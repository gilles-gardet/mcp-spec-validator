{
  "name": "integration/mcp",
  "data": {
    "name": "github-mcp-server",
    "connections": [
      {
        "type": "stdio",
        "command": "docker",
        "args": ["run", "-i", "--rm", "ghcr.io/github/github-mcp-server"],
        "env_vars": [
          {
            "name": "GITHUB_PERSONAL_ACCESS_TOKEN",
            "description": "GitHub personal access token with repo scope",
            "required": true
          }
        ]
      }
    ]
  }
}
